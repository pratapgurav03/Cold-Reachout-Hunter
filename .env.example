# ── COLD REACHOUT HUNTER — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required: Your Anthropic API key for AI email generation
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional but recommended: Hunter.io for accurate email finding
# Free tier = 25 searches/month — enough to get started
# Get at: https://hunter.io/users/sign_up
HUNTER_API_KEY=your-hunter-key-here

# Required for sending emails: Gmail App Password
# Step 1: Enable 2FA on your Google account
# Step 2: Go to https://myaccount.google.com/apppasswords
# Step 3: Select "Mail" + "Mac" → Generate
# Step 4: Paste the 16-char password below (spaces optional)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
