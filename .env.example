# ── COLD REACHOUT HUNTER — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# Required: Your Anthropic API key for AI email generation
# Get one at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional but recommended: Hunter.io for accurate email finding
# Free tier = 25 searches/month — enough to get started
# Get at: https://hunter.io/users/sign_up
HUNTER_API_KEY=your-hunter-key-here

# Gmail App Password (legacy — OAuth below is preferred)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Required for Gmail OAuth ("Connect Gmail" button)
# Step 1: Go to https://console.cloud.google.com/
# Step 2: Create project → Enable Gmail API
# Step 3: APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web Application)
# Step 4: Add Authorized Redirect URI: http://localhost:5050/auth/gmail/callback
# Step 5: Copy Client ID and Secret below
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret-here
GOOGLE_REDIRECT_URI=http://localhost:5050/auth/gmail/callback

# Auth / Database
SECRET_KEY=change-this-to-a-long-random-string
DATABASE_URL=
